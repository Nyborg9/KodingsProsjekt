@model List<WebApplication2.Models.AreaChange>
@{
    ViewData["Title"] = "Overview";
}

<h2>Overview of Registered Changes</h2>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>GeoJSON</th>
            <th>Description</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var change in Model)
        {
            <tr>
                <td>@change.Id</td>
                <td>@change.GeoJson</td>
                <td>@change.Description</td>
            </tr>
        }
    </tbody>
</table>